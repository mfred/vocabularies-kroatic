rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Globale Bestenliste — jeder kann lesen, jeder Eingeloggte schreibt
    // nur seinen eigenen Score (uid muss passen). Keine Edits / Deletes.
    match /scores/{sessionId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid
        && request.resource.data.scorePoints is int
        && request.resource.data.scorePoints >= 0
        && request.resource.data.lessonId is string
        && request.resource.data.direction is string
        && request.resource.data.format is string
        && request.resource.data.correctCount is int
        && request.resource.data.totalCount is int
        && request.resource.data.durationMs is int
        && request.resource.data.hintsUsed is int
        && request.resource.data.finishedAt is timestamp;
      allow update, delete: if false;
    }

    // Spieler-Profile für Freundes-Suche. Jeder Eingeloggte darf alle Profile
    // lesen (Suche per Email/Name/Code), aber nur sein eigenes anlegen/ändern.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // Freundschafts-Anfragen.
    match /friend_requests/{requestId} {
      allow read: if request.auth != null
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.toUid != request.auth.uid
        && request.resource.data.status == 'pending';
      // Empfänger darf annehmen/ablehnen, Sender darf zurückziehen.
      allow update: if request.auth != null
        && (
          (resource.data.toUid == request.auth.uid
            && request.resource.data.status in ['accepted', 'declined'])
          || (resource.data.fromUid == request.auth.uid
            && request.resource.data.status == 'cancelled')
        )
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toUid == resource.data.toUid;
      allow delete: if false;
    }

    // Freundschaften — eine Zeile pro Paar, ID = "<uidA>_<uidB>" sortiert.
    match /friendships/{pairKey} {
      // `get` muss bei nicht-existenten Pair-Docs sauber `exists=false`
      // zurückliefern können — dafür wird die Rule null-tolerant gemacht.
      // Sonst wirft Firestore bei z. B. `areFriends(...)` permission-denied,
      // wenn das Pair noch nie existierte (resource.data.uids ist undefined).
      allow get: if request.auth != null
        && (
          !exists(/databases/$(database)/documents/friendships/$(pairKey))
          || request.auth.uid in resource.data.uids
        );
      // `list` (Collection-Queries) bleibt strikt — nur Mitglieder dürfen
      // enumerieren (in der App via watchFriendUids mit arrayContains).
      allow list: if request.auth != null
        && request.auth.uid in resource.data.uids;
      // Beide Beteiligten dürfen anlegen (im Batch beim Accept). Wir prüfen
      // hier nur, dass der Schreibende selbst in `uids` steht.
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.uids
        && request.resource.data.uids.size() == 2;
      // Löschen darf jedes Mitglied (= Entfreunden).
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.uids;
      allow update: if false;
    }

    // Duelle — zwei Beteiligte, asynchroner Lauf.
    match /duels/{duelId} {
      allow read: if request.auth != null
        && (resource.data.challengerUid == request.auth.uid
            || resource.data.opponentUid == request.auth.uid);
      // Challenger erstellt das Doc mit komplettem Set + eigenem Ergebnis.
      allow create: if request.auth != null
        && request.resource.data.challengerUid == request.auth.uid
        && request.resource.data.opponentUid is string
        && request.resource.data.opponentUid != request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.rounds is list
        && request.resource.data.challengerResult is map;
      // Updates: nur Opponent darf accept/decline/submit. Schreibgeschützte
      // Felder bleiben unverändert.
      allow update: if request.auth != null
        && resource.data.opponentUid == request.auth.uid
        && request.resource.data.challengerUid == resource.data.challengerUid
        && request.resource.data.opponentUid == resource.data.opponentUid
        && request.resource.data.rounds == resource.data.rounds
        && request.resource.data.challengerResult == resource.data.challengerResult;
      allow delete: if false;
    }
  }
}
